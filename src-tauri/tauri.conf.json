{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Settings Manager",
  "version": "3.4.0",
  "identifier": "com.taidoc.claude-settings-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Settings Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kevintsai1202/claude-settings/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBNTg2NzRGOTkxM0U2OQpSV1JwUHBINWRJYWxDRzlzS2tPa045VEVkamRtSHd5d24rMXRBd0dTakd2ck4rS0l0dlhNcjh4Qwo="
    }
  }
}
