{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "C:/**" },
        { "path": "D:/**" },
        { "path": "E:/**" },
        { "path": "/Users/**" },
        { "path": "/Applications/**" },
        { "path": "/Library/**" },
        { "path": "/etc/**" },
        { "path": "/opt/**" },
        { "path": "/usr/local/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open"
  ]
}
